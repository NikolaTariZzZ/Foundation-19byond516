	language = list(LANGUAGE_HUMAN_ARABIC)

/decl/cultural_info/culture/human/eastslavic
	name = CULTURE_HUMAN_EASTSLAVIC
	description = "Вы родом из Восточной Европы (Россия, Украина или Беларусь). Восточнославянская культура известна своим влиянием на Восточную Европу и западную Азию. \
	История восточнославянской культуры — это история миграции и единения с другими славянскими государствами в условиях сурового климата. \
	Большинство восточных славян известны как великая сила в войнах, осторожные и консервативные защитники статус-кво."
	economic_power = 0.44
	language = list(LANGUAGE_HUMAN_RUSSIAN)

/decl/cultural_info/culture/human/chinese
	name = CULTURE_HUMAN_CHINESE
	description = "Вы родом из материкового Китая или Тайваня. Китайская культура основана на авторитете и порядке, \
	культурно значимая для многих этнических китайцев за рубежом по всему миру. Хотя географическое разнообразие уже не такое, как в прошлом, в большинстве \
	регионов есть по крайней мере один или два гигаполиса, в которых сосредоточена большая часть населения, а оставшиеся жители проживают в сельских деревнях. \
	Длительный период индустриализации в материковом Китае и на Тайване привёл к тому, что большая часть населения стала высокообразованной и продуктивной, преодолев то преимущество, которое раньше имели западные державы, и стремится избежать ошибок прошлого. Большинство китайцев — \
	дружелюбный, но осторожный народ, считающий себя ближе к порядку и духовным ценностям."
	economic_power = 0.65
	language = list(LANGUAGE_HUMAN_CHINESE)

/decl/cultural_info/culture/human/japanese
	name = CULTURE_HUMAN_JAPANESE
	description = "Вы родом из Японии. Японская культура основана на чести и гармонии, \
	культурно значимая для многих людей по всему миру. Хотя экономическая мощь уже не та, что в прошлом, в большинстве \
