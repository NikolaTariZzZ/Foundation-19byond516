//////// EARTH CULTURES //////////

/decl/cultural_info/culture/human/earthling
	name = CULTURE_HUMAN_EARTH
	description = "Вы родом из Соединённых Штатов Америки, земли свободных. Американская культура на протяжении столетий представляла собой бурлящий котёл других культур; старые штаты, хотя и утратили былое политическое значение, по-прежнему \
	культурно значимы для многих людей по всему миру. Хотя географическое разнообразие уже не столь велико, как в прошлом, в большинстве \
	штатов есть по крайней мере один мегаполис, в котором сосредоточена значительная часть населения, а оставшиеся жители проживают в сельских городках. \
	Длительный период восстановления Соединённых Штатов привёл к тому, что большая часть населения стала бережно относиться к окружающей среде и активно заниматься её сохранением, стремясь избежать ошибок прошлого. Большинство американцев — \
	патриотичный народ, считающий себя ближе к свободе и демократии, чем большинство других стран."
	economic_power = 0.95

/decl/cultural_info/culture/human/latinamerican
	name = CULTURE_HUMAN_LATINAMERICAN
	description = "Вы родом из Южной Америки, края джунглей. Латиноамериканская культура сохранилась практически в том же виде, что и в 2000-х годах, а старые испанские и португальские нации застыли в противостоянии за контроль, по-прежнему \
	разделённые в культурном плане на испано- и португалоязычных. Хотя разнообразие и сохранилось, как и в прошлом, в большинстве \
	латиноамериканских стран есть по крайней мере один крупный город с населением более полутора миллионов человек, а остальные граждане живут в сельских аграрных деревнях. \
	Это беззаботный народ, который считает себя ближе к природе и аграрному укладу, чем большинство других стран."
	economic_power = 0.25
	language = list(LANGUAGE_HUMAN_SPANISH)

/decl/cultural_info/culture/human/british
	name = CULTURE_HUMAN_BRITISH
	description = "Вы родом из одной из стран, входящих в Британское Содружество (Англия, Канада, Австралия и большинство английских колоний). Британская культура в значительной степени строится вокруг бюрократических идеалов и многочисленных колоний. \
	Для многих людей по всему миру она имеет большое значение. Большая часть Великобритании покрыта городами, в то время как Австралия и Канада остаются преимущественно сельскими. \
	В каждой из стран есть по крайней мере три мегаполиса, в которых сосредоточена значительная часть населения, а также некоторое количество небольших городков. \
	Большинство британцев открыты для иностранных культур и религий, существующих в пределах их границ."
	economic_power = 1.0

/decl/cultural_info/culture/human/goidelic
	name = CULTURE_HUMAN_GOIDELIC
	description = "Вы родом из Ирландии, Шотландии или с острова Мэн. Гойдельская культура — древняя, уходящая корнями во времена до того, как англосаксы захватили острова. \
	Большая часть Ирландии, Шотландии и острова Мэн покрыта полями и лесами, с несколькими городами. \
	Большинство гойдельцев не слишком заботятся о власти или о том, что о них думают другие."
	economic_power = 0.40

/decl/cultural_info/culture/human/german
	name = CULTURE_HUMAN_GERMAN
	description = "Вы родом из Германии, Австрии или западной Польши. Немецкая культура сформировалась относительно недавно, в последние 200 лет, под влиянием дипломатии и войн. \
	Большинство немцев — весёлый народ, которому нравится компания других. Немецкий народ воссоединён уже довольно давно, после окончания холодной войны, и за плечами у него очень смешанное прошлое."
	economic_power = 0.55
	language = list(LANGUAGE_HUMAN_GERMAN)

/decl/cultural_info/culture/human/italian
	name = CULTURE_HUMAN_ITALIAN
	description = "Вы родом из Италии или Аргентины. Итальянская культура сформировалась относительно недавно, в последние 100 лет, под влиянием дипломатии и войн конца 1800-х годов. \
	Большинство итальянцев экспрессивны в жестах и любят свою семью. Итальянский народ очень трепетно относится к своей истории в Европе."
	economic_power = 0.45
	language = list(LANGUAGE_HUMAN_ITALIAN)

/decl/cultural_info/culture/human/french
	name = CULTURE_HUMAN_FRENCH
	description = "Вы родом из Квебека (Канада), Франции или одной из французских колоний. Французская культура вращается вокруг моды, кухни, искусства и кино. \
	Большинство французов известны своим хорошим этикетом, но при этом почти всегда прибывают с опозданием."
